# ─── Secrets / Env ─────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*-credentials.json
service-account*.json
gcp-key*.json

# ─── Node / Frontend ───────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
*.tsbuildinfo
.eslintcache

# ─── Go / Backend ──────────────────────────────────────────
backend/server
backend/server.exe
backend/tmp/
backend/coverage.out
backend/dist/
# sqlc generated 仍 commit（編譯期保證），不 ignore

# ─── Docker ────────────────────────────────────────────────
backend/.docker/

# ─── Terraform ─────────────────────────────────────────────
# state 含 secret（DB password / SA key 等），永遠不該 commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
*.tfvars
*.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ─── IDE / Editor ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── AI tooling (per-machine state, never commit) ──────────
# Claude Code 的 ScheduleWakeup / loop / scheduled_tasks 會在這裡寫
# session id / pid / timestamp lock；屬於本機運行狀態，不該進 git。
.claude/
# Playwright MCP 每次 verification run 寫 page snapshots + console
# logs；本機暫存、不該進 repo（否則每次 review run 都會 churn diff）。
.playwright-mcp/

# ─── Build / CI artifacts ──────────────────────────────────
*.log
.cache/

# ─── Local override ────────────────────────────────────────
*.local
