# Phase A deploy target. Copy to infra/phase-a.env for local overrides.
# Do not put secrets in this file or commit infra/phase-a.env.

PROJECT_ID=artogo-v2
PROJECT_NUMBER=968864738717
REGION=asia-east1

AR_REPOSITORY=internal
IMAGE_NAME=quote-app

SQL_INSTANCE=artogo-auth-db
DB_STAGING=quotes_staging
DB_PROD=quotes_prod
DB_USER_STAGING=quote_app_staging
DB_USER_PROD=quote_app_prod
DB_ADMIN_USER=postgres

# Required for infra/scripts/phase-a-setup.sh --apply to grant database/schema
# ownership to quote_app_* roles. Prefer Secret Manager over a local plaintext
# password when possible.
# DB_ADMIN_PASSWORD_SECRET=
# DB_ADMIN_PASSWORD=

RUN_SA=quote-app-runner
RUN_SA_STAGING=quote-app-staging-runner
RUN_SA_PROD=quote-app-prod-runner
EXPECTED_DEPLOYER_SA=quote-app-staging-deployer
DEPLOYER_SA=quote-app-staging-deployer
LEGACY_DEPLOYER_SA=github-actions-deployer

WIF_POOL=github-actions
WIF_PROVIDER=github
GITHUB_REPOSITORY=ARTOGO/Artway-quote-system
WIF_DEPLOY_REF=refs/heads/staging
WIF_DEPLOY_WORKFLOW_REF=ARTOGO/Artway-quote-system/.github/workflows/deploy-staging.yml@refs/heads/staging

URL_MAP=https
HTTPS_TARGET_PROXY=https-target-proxy-2
CERT_NAME=quote-app-cert
HOST_STAGING=quote-staging.artogo.co
HOST_PROD=quote.artogo.co

# Required only when applying IAP on backend services.
# IAP_OAUTH_CLIENT_ID=
# IAP_OAUTH_CLIENT_SECRET=
