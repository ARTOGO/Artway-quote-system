# Backend environment variables — copy to .env for local dev (gitignored)
# Cloud Run prod/staging 從 Secret Manager 注入、不要在這寫 production 值。

# HTTP port (Cloud Run 自動注入；本機預設 8080)
PORT=8080

# Postgres connection (pgx format). 本機跟 docker-compose 用同樣 password。
DATABASE_URL=postgres://quote_app:dev_password@localhost:5432/quotes?sslmode=disable

# Environment: dev / staging / prod
# - dev: bypass IAP（讀 DEV_USER_EMAIL 模擬使用者）
# - staging / prod: 走 IAP X-Goog-Authenticated-User-Email header
ENV=dev

# Dev mode 模擬使用者 email（只在 ENV=dev 生效；prod/staging 一律走 IAP header）
DEV_USER_EMAIL=peter@artogo.co
